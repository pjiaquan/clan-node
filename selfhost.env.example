# Copy this file to `selfhost.env` before running docker compose.
# Generate strong secrets before exposing the app to any network.

ENVIRONMENT=development
FRONTEND_ORIGIN=http://localhost:8080
EMAIL_VERIFICATION_URL_BASE=http://localhost:8080
PASSWORD_RESET_URL_BASE=http://localhost:8080

# Recommended for controlled initial admin bootstrap.
# Example: openssl rand -base64 32
AUTH_ENCRYPTION_KEY=<INSERT_STRONG_32_BYTE_BASE64_KEY>

# Recommended for controlled initial admin bootstrap.
ADMIN_SETUP_TOKEN=<INSERT_RANDOM_TOKEN>

# Optional mail delivery.
BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=Clan Node

# Optional Telegram notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional dual-write replication.
DUAL_WRITE_REMOTE=
DUAL_WRITE_REMOTE_BASE=
DUAL_WRITE_REMOTE_ORIGIN=
DUAL_WRITE_REMOTE_USER=
DUAL_WRITE_REMOTE_PASS=
DUAL_WRITE_SHARED_SECRET=
